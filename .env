# MongoDB Configuration
MONGO_ROOT_USER=opencb
MONGO_ROOT_PASSWORD=opencb_secure_pass
MONGO_DATABASE=opencga

# OpenCGA Configuration
OPENCGA_JAVA_MEMORY=8g
OPENCGA_DB_HOST=mongodb
OPENCGA_DB_PORT=27017
OPENCGA_DB_USER=opencb
OPENCGA_DB_PASSWORD=opencb_secure_pass
OPENCGA_DB_NAME=opencga

# OpenSearch
OPENSEARCH_PASSWORD=OpenSearch@123
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# Logging
LOG_LEVEL=INFO

# REST API
OPENCGA_REST_PORT=8080
OPENCGA_REST_HOST=0.0.0.0
